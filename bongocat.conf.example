# ═══════════════════════════════════════════════════════════════════════════════
# BONGO CAT CONFIG - macOS Default Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Save this file to: ~/.config/bongocat/bongocat.conf
# Run with: ./build/bongocat --watch-config
# ═══════════════════════════════════════════════════════════════════════════════

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ APPEARANCE                                                                  │
# └─────────────────────────────────────────────────────────────────────────────┘

# Cat size and position
cat_height=110
cat_align=center
cat_x_offset=0
cat_y_offset=0

# Deprecated: no-op with SVG rendering (antialiasing is always enabled)
# enable_antialiasing=1

# Flip the cat
mirror_x=0
mirror_y=0

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ OVERLAY BAR                                                                 │
# └─────────────────────────────────────────────────────────────────────────────┘

# Bar dimensions
overlay_height=120

# Background: 0=transparent, 255=opaque
overlay_opacity=0

# Position: top, bottom
overlay_position=top

# Layer: top (above windows), overlay (always visible, fullscreen auto-hide detection disabled)
layer=top

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ INPUT MONITORING                                                            │
# └─────────────────────────────────────────────────────────────────────────────┘

# macOS uses global keyboard events after Input Monitoring permission is
# granted in System Settings > Privacy & Security > Input Monitoring.
# keyboard_device and keyboard_name are not needed on macOS.

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ MULTI-MONITOR (optional)                                                    │
# └─────────────────────────────────────────────────────────────────────────────┘

# Leave commented to auto-detect
# Use the display names shown in System Settings > Displays.
# monitor=Built-in Retina Display
# monitor=Built-in Retina Display,Studio Display

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ ANIMATION                                                                   │
# └─────────────────────────────────────────────────────────────────────────────┘

fps=60
idle_frame=0
keypress_duration=100

# Hand mapping: 0=random hands, 1=left keys→left hand, right keys→right hand
enable_hand_mapping=1

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ SLEEP MODE (optional)                                                       │
# └─────────────────────────────────────────────────────────────────────────────┘

# Hide after N seconds of no keyboard activity (0=disabled)
# When triggered, displays a dedicated sleeping animation frame
idle_sleep_timeout=0

# Scheduled sleep (requires enable_scheduled_sleep=1)
enable_scheduled_sleep=0
sleep_begin=22:00
sleep_end=06:00

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ FULLSCREEN                                                                  │
# └─────────────────────────────────────────────────────────────────────────────┘

# Keep overlay visible even when a fullscreen window is detected (0=hide, 1=show)
# disable_fullscreen_hide=0

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ INPUT RESCAN                                                                │
# └─────────────────────────────────────────────────────────────────────────────┘

# Ignored by the macOS backend; kept for config compatibility.
# hotplug_scan_interval=30

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ TEST ANIMATION                                                              │
# └─────────────────────────────────────────────────────────────────────────────┘

# Duration of each test animation frame in milliseconds
# test_animation_duration=200
# Interval between test animation cycles in milliseconds (0=disabled)
# test_animation_interval=0

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ DEBUG                                                                       │
# └─────────────────────────────────────────────────────────────────────────────┘
#
# WARNING: Enabling debug mode will log keystrokes!!
#
# Enable debug logging (0=disabled, 1=enabled)
enable_debug=0
